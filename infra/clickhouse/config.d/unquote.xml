<!-- Server tuning for a shared 16GB box: ClickHouse gets at most half the RAM,
     and the system logs that silently eat disks are trimmed or disabled. -->
<clickhouse>
  <max_server_memory_usage_to_ram_ratio>0.65</max_server_memory_usage_to_ram_ratio>
  <!-- All three HNSW indexes (lines 3.3GB, beats 1.9GB, segments 0.3GB) must
       fit at once or queries thrash the cache reloading them. -->
  <vector_similarity_index_cache_size>8589934592</vector_similarity_index_cache_size>

  <query_log replace="1">
    <database>system</database>
    <table>query_log</table>
    <engine>ENGINE = MergeTree PARTITION BY event_date ORDER BY event_time TTL event_date + INTERVAL 7 DAY</engine>
    <flush_interval_milliseconds>7500</flush_interval_milliseconds>
  </query_log>

  <metric_log remove="1" />
  <asynchronous_metric_log remove="1" />
  <trace_log remove="1" />
  <text_log remove="1" />
  <part_log remove="1" />
  <processors_profile_log remove="1" />
</clickhouse>
