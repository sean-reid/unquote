# TMDb API (https://www.themoviedb.org/settings/api), used by the pipeline only
TMDB_API_KEY=

# ClickHouse connection for the web app and pipeline load stage
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=unquote-local

# Production server for infra/ops push and deploy scripts
UNQUOTE_HOST=

# OpenSubtitles REST API (transcript upgrades); free tier is 5 downloads a day
OPENSUBTITLES_API_KEY=
